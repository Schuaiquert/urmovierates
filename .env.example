# Application
NODE_ENV=development
PORT=3000
APP_NAME=urmovierates

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urmovierates

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-super-secret-key-min-32-characters-long
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis Cache TTL (seconds)
CACHE_TTL=3600

# API Key — sent in `X-API-Key` header to every protected route
# Generate with: openssl rand -hex 32
API_KEY=generate-with-openssl-rand-hex-32-min-16-chars